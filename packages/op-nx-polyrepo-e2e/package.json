{
  "name": "nx-openpolyrepo-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "projectType": "application",
    "sourceRoot": "packages/op-nx-polyrepo-e2e/src",
    "implicitDependencies": [
      "nx-openpolyrepo"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/vitest:test",
        "outputs": [
          "{projectRoot}/test-output/vitest/coverage"
        ],
        "options": {
          "configFile": "packages/op-nx-polyrepo-e2e/vitest.config.mts"
        },
        "dependsOn": [
          "^build"
        ]
      }
    }
  }
}

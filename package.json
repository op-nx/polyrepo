{
  "name": "@op-nx/source",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "nx run-many -t build --exclude tag:polyrepo:external --skipSync",
    "build:polyrepo": "nx run-many -t build --skipSync",
    "build:external": "nx run-many -t build -p tag:polyrepo:external --skipSync",
    "test": "nx run-many -t test --exclude tag:polyrepo:external --skipSync",
    "test:polyrepo": "nx run-many -t test --skipSync",
    "test:external": "nx run-many -t test -p tag:polyrepo:external --skipSync",
    "lint": "nx run-many -t lint --exclude tag:polyrepo:external --skipSync",
    "lint:polyrepo": "nx run-many -t lint --skipSync",
    "lint:external": "nx run-many -t lint -p tag:polyrepo:external --skipSync",
    "typecheck": "nx run-many -t typecheck --exclude tag:polyrepo:external --skipSync",
    "typecheck:polyrepo": "nx run-many -t typecheck --skipSync",
    "typecheck:external": "nx run-many -t typecheck -p tag:polyrepo:external --skipSync",
    "e2e": "nx e2e op-nx-polyrepo-e2e",
    "graph": "nx graph",
    "format": "nx format",
    "format:check": "nx format:check"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^9.8.0",
    "@nx/devkit": "^22.5.4",
    "@nx/esbuild": "^22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "^22.5.4",
    "@nx/js": "^22.5.4",
    "@nx/node": "^22.5.4",
    "@nx/plugin": "^22.5.4",
    "@nx/vite": "^22.5.4",
    "@nx/vitest": "^22.5.4",
    "@nx/web": "^22.5.4",
    "@nx/workspace": "^22.5.4",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/eslint-plugin": "^1.6.11",
    "@vitest/ui": "^4.0.0",
    "create-nx-workspace": "^22.5.4",
    "esbuild": "^0.25.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jiti": "2.4.2",
    "jsdom": "^27.1.0",
    "nx": "^22.5.4",
    "prettier": "~3.6.2",
    "testcontainers": "^11.12.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "verdaccio": "^6.0.5",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}

{
  "name": "nx-openpolyrepo",
  "version": "0.0.1",
  "executors": "./executors.json",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@nx-openpolyrepo/source": "./src/index.ts",
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "nx": {
    "release": {
      "version": {
        "manifestRootsToUpdate": ["dist/{projectRoot}"],
        "currentVersionResolver": "git-tag",
        "fallbackCurrentVersionResolver": "disk"
      }
    },
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "dist/packages/nx-openpolyrepo",
          "main": "packages/nx-openpolyrepo/src/index.ts",
          "tsConfig": "packages/nx-openpolyrepo/tsconfig.lib.json",
          "assets": [
            {
              "input": "./packages/nx-openpolyrepo/src",
              "glob": "**/!(*.ts)",
              "output": "./src"
            },
            {
              "input": "./packages/nx-openpolyrepo/src",
              "glob": "**/*.d.ts",
              "output": "./src"
            },
            {
              "input": "./packages/nx-openpolyrepo",
              "glob": "executors.json",
              "output": "."
            }
          ]
        }
      },
      "nx-release-publish": {
        "executor": "@nx/js:release-publish",
        "options": {
          "packageRoot": "dist/{projectRoot}"
        }
      }
    }
  },
  "dependencies": {
    "@nx/devkit": ">=20.0.0",
    "tslib": "^2.3.0",
    "zod": "^4.0.0"
  }
}

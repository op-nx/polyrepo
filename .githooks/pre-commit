#!/bin/sh
#
# Pre-commit hook: verify staged files pass nx format:check.
# Auto-formats and re-stages unformatted files so the commit includes the fixes.
# Pipes file lists through xargs to stay within OS argument length limits.

staged_files=$(git diff --cached --name-only --diff-filter=d)

if [ -z "$staged_files" ]; then
  exit 0
fi

unformatted=$(echo "$staged_files" | xargs npm exec nx -- format:check --files 2>/dev/null)

if [ -z "$unformatted" ]; then
  exit 0
fi

echo "$unformatted" | xargs npm exec nx -- format --files
echo "$unformatted" | xargs git add
